# === Telegram ===
# Token from @BotFather
BOT_TOKEN=123456:ABC-PASTE-YOUR-TOKEN

# === Redirect service ===
# Base address of short links (NO trailing slash)
# Production - real domain. Local - http://localhost:8000
BASE_URL=https://tyk.ru

# Host/port the FastAPI redirect binds to
REDIRECT_HOST=0.0.0.0
REDIRECT_PORT=8000

# === Database ===
# Path to the SQLite file (async aiosqlite driver)
DATABASE_URL=sqlite+aiosqlite:///./shorter_links.db

# === Limits / anti-spam ===
# Max active links per user
MAX_LINKS_PER_USER=100

# Random slug length
SLUG_LENGTH=6
